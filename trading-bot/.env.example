# ──────────────────────────────────────────────────────────────────────────
# Tracer v1 — environment variables
# Copy to `.env.local` for local dev. In production these live in Vercel
# project settings → Environment Variables. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── Alpaca (brokerage + market data) ──────────────────────────────────────
# Create keys at https://alpaca.markets. Use PAPER keys first.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Trading API base URL. PAPER by default — do not change to live until the
# paper→live gate in the README is genuinely met.
#   paper: https://paper-api.alpaca.markets
#   live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market data API base + feed. Free accounts get the IEX feed.
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# ── Supabase (state + logs) ───────────────────────────────────────────────
# Project URL and the SERVICE ROLE key (server-side only — never exposed to a
# browser; the only "page" is a server-rendered status dashboard).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Alerting (pick at least one; otherwise alerts only go to run_log) ──────
# Generic webhook: POST JSON {title, body, level, data}. Works with Slack/
# Discord/Make/ntfy/IFTTT/your phone. Easiest, no signup.
ALERT_WEBHOOK_URL=

# Resend email (optional). https://resend.com
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=Tracer Bot <bot@yourdomain.com>

# Generic alert provider key kept for spec parity (used if you wire a custom
# provider in src/lib/alerts.ts).
ALERT_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────
# Shared secret that protects the cron/trigger endpoints. Vercel Cron sends
# this automatically as `Authorization: Bearer <CRON_SECRET>` when set.
# Generate one: `openssl rand -hex 32`
CRON_SECRET=

# Optional token gating the read-only status page (?token=...). If unset, the
# page renders with a warning that it is unauthenticated.
STATUS_TOKEN=
